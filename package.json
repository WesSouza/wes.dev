{
  "private": true,
  "name": "wes-dev",
  "version": "2022.11.19",
  "description": "https://wes.dev/",
  "homepage": "https://wes.dev/",
  "repository": "github:WesSouza/wes.dev",
  "author": "Wes Souza <hey@wes.dev>",
  "license": "MIT",
  "keywords": [
    "personal website",
    "Wes Souza",
    "Wesley de Souza"
  ],
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check && tsc --noEmit && eslint . && prettier --check src",
    "check:fix": "eslint --fix . && prettier --write src",
    "dev": "astro dev",
    "generate-acknowledgements": "tsx ./src/scripts/Wes95_Acknowledgements.ts",
    "generate-sprites": "tsx ./src/scripts/Wes95_Sprites.ts && prettier --write src/styles/Wes95/Icons.generated.css",
    "preview": "astro build && wrangler dev --config ./dist/server/wrangler.json",
    "start": "astro dev"
  },
  "engines": {
    "node": "22",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.4.0",
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.1",
    "@astrojs/solid-js": "6.0.1",
    "@atproto/api": "^0.19.11",
    "@solid-primitives/resize-observer": "^2.1.5",
    "@trpc/client": "11.16.0",
    "@trpc/server": "11.16.0",
    "anchorme": "^3.0.8",
    "astro": "6.1.9",
    "solid-js": "^1.9.12",
    "solid-markdown": "^2.1.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6",
    "zod-search-params": "^0.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@types/license-checker": "^25.0.6",
    "@types/node": "25.6.0",
    "@types/spritesmith": "^3.4.5",
    "@types/youtube": "^0.2.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "license-checker": "^25.0.1",
    "prettier": "3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "spritesmith": "^3.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "wrangler": "^4.84.1"
  }
}
