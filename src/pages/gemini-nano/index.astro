---
import HeadMeta from '../../components/HeadMeta.astro';
---

<!doctype html>
<!-- Source code available at https://github.com/WesSouza/wes.dev/ -->
<html lang="en">
  <head>
    <HeadMeta title={'Mod Me - Wes.dev'} />
  </head>
  <body>
    <iframe id="canvas" width="100%" height="200"></iframe>
    <hr />
    Status: <span id="status">unknown</span>
    <hr />
    <input id="prompt" />
    <div id="chat"></div>

    <script>
      import * as smd from 'streaming-markdown';

      type EvalWindow = Window & {
        eval(code: string): unknown;
      };

      type ToolRendererData = smd.Default_Renderer_Data & {
        nodes: HTMLElement[];
        tool_call: boolean;
      };

      type MaybeError = {
        type?: unknown;
        message?: unknown;
      };

      function stringify(result: unknown) {
        try {
          return JSON.stringify(result);
        } catch {
          return '"The result could not be stringified."';
        }
      }

      const options: LanguageModelOptions = {
        expectedInputs: [
          { type: 'text', languages: ['en'] },
          // { type: 'tool-response' },
        ],
        expectedOutputs: [
          { type: 'text', languages: ['en'] },
          // { type: 'tool-call' },
        ],
      };

      async function checkDumbAvailability() {
        let availability: LanguageModelAvailability = 'unavailable';
        try {
          availability = await LanguageModel.availability(options);
        } catch (error) {
          console.error(error);
        } finally {
          return availability;
        }
      }

      async function createDumbMachine(
        options: {
          onDownloadProgress?: (event: { loaded: number }) => void;
        } = {},
      ) {
        return LanguageModel.create({
          ...options,
          initialPrompts: [
            {
              role: 'system',
              content: [
                'You are a web assistant with tool call capabilities. RULES:',
                '1. To run code, use',
                '  ```tool_call',
                '  someJavaScriptCode()',
                '  ```',
                '2. After a tool_call you will receive a tool_response message with the results as JSON.',
                '',
                'EXAMPLE:',
                'User: Find how many elements there are in the page.',
                'Assistant:',
                '  ```tool_call',
                "  document.querySelectorAll('*').length;",
                '  ```',
                '',
                'User:',
                '  ```tool_response',
                '  {"ok":true,"result":4',
                '  ```',
                '',
                'Assistant:',
                '  There are 4 elements in the page.',
                '',
              ].join('\n'),
            },
          ],
          monitor(monitor) {
            console.log(monitor);
            monitor.addEventListener('downloadprogress', (event) => {
              console.log(event);
              options.onDownloadProgress?.(event);
            });
          },
        });
      }

      function findCodeBlock(nodes: HTMLElement[]) {
        let codeEl: HTMLElement | undefined;
        for (let i = nodes.length - 1; i >= 0; i--) {
          const currentNode = nodes[i];
          if (!currentNode) {
            continue;
          }

          if (
            currentNode.tagName === 'CODE' &&
            currentNode.className === 'tool_call'
          ) {
            codeEl = nodes[i];
            break;
          }
        }

        return codeEl;
      }

      function getErrorDetails(error: unknown) {
        if (!error || typeof error !== 'object') {
          return {
            error_type: typeof error,
            error_message: String(error),
          };
        }

        const maybeError = error as MaybeError;

        return {
          error_type:
            typeof maybeError.type === 'string' ? maybeError.type : 'Error',
          error_message:
            typeof maybeError.message === 'string'
              ? maybeError.message
              : String(error),
        };
      }

      function isPromiseLike(value: unknown): value is Promise<unknown> {
        return (
          !!value &&
          (typeof value === 'object' || typeof value === 'function') &&
          'then' in value &&
          typeof value.then === 'function'
        );
      }

      async function main() {
        const canvas = document.getElementById('canvas');
        const status = document.getElementById('status');
        const chat = document.getElementById('chat');
        const promptInput = document.getElementById('prompt');

        if (
          !(canvas instanceof HTMLIFrameElement) ||
          !(chat instanceof HTMLElement) ||
          !(promptInput instanceof HTMLInputElement) ||
          !(status instanceof HTMLElement)
        ) {
          throw new Error('Gemini Nano page is missing required DOM elements.');
        }

        let session: LanguageModelSession | undefined = undefined;
        let thinking = false;
        let nextPrompt: string | null = null;

        if (!canvas.contentDocument || !canvas.contentWindow) {
          throw new Error('Gemini Nano iframe is unavailable.');
        }

        canvas.contentDocument.body.innerHTML = '<div id="root">Hello!</div>';
        const chatRoot = chat;
        const canvasWindow = canvas.contentWindow as EvalWindow;

        async function installDumbModel() {
          const availability = await checkDumbAvailability();
          status!.innerText = availability;

          session = await createDumbMachine({
            onDownloadProgress(event) {
              status!.innerText =
                event.loaded < 1
                  ? `downloading... ${(event.loaded * 100).toFixed(2)}`
                  : 'ready';
            },
          });
        }

        const renderer: smd.Renderer<ToolRendererData> = {
          add_token: (data, type) => {
            // console.log('add_token', data.nodes, data.tool_call, type);
            smd.default_add_token(data, type);
          },
          end_token: (data) => {
            // console.log('end_token', data.nodes, data.tool_call, type);
            smd.default_end_token(data);
            if (data.tool_call) {
              // console.log(data.nodes);
              const codeEl = findCodeBlock(data.nodes);

              if (codeEl) {
                try {
                  const code = codeEl.textContent;
                  console.group('eval');
                  console.log(code);
                  console.groupEnd();
                  const result = canvasWindow.eval(code ?? '');
                  if (isPromiseLike(result)) {
                    result
                      .then((promiseResult) => {
                        promptSync(
                          [
                            '```tool_response',
                            stringify({ ok: true, result: promiseResult }),
                            '```',
                          ].join('\n'),
                        );
                      })
                      .catch((error: unknown) => {
                        promptSync(
                          [
                            '```tool_response',
                            stringify({
                              ok: false,
                              ...getErrorDetails(error),
                            }),
                            '```',
                          ].join('\n'),
                        );
                      });
                  } else {
                    promptSync(
                      [
                        '```tool_response',
                        stringify({ ok: true, result }),
                        '```',
                      ].join('\n'),
                    );
                  }
                } catch (error) {
                  promptSync(
                    [
                      '```tool_response',
                      stringify({
                        ok: false,
                        ...getErrorDetails(error),
                      }),
                      '```',
                    ].join('\n'),
                  );
                  console.error(error);
                }
              }

              data.tool_call = false;
            }
          },
          add_text: (data, text) => {
            // console.log('add_text', data.nodes, data.tool_call, text);
            smd.default_add_text(data, text);
          },
          set_attr: (data, type, value) => {
            smd.default_set_attr(data, type, value);
            // console.log('set_attr', data.nodes, data.tool_call, type, value);
            if (type === smd.Attr.Lang && value === 'tool_call') {
              data.tool_call = true;
              const codeEl = findCodeBlock(data.nodes);
              if (codeEl) {
                codeEl.style.display = 'none';
              }
            }
          },
          data: {
            nodes: [chat],
            index: 0,
            tool_call: false,
          },
        };

        async function prompt(text: string) {
          if (!session) {
            return;
          }

          if (thinking) {
            nextPrompt = text;
            return;
          }

          renderer.data = {
            nodes: [chatRoot],
            index: 0,
            tool_call: false,
          };
          const parser = smd.parser(renderer);

          const stream = session.promptStreaming(text);
          thinking = true;

          console.group('request');
          console.log(text);
          console.groupEnd();
          let result = '';
          for await (const chunk of stream) {
            smd.parser_write(parser, chunk);
            result += chunk;
          }
          console.group('response');
          console.log(result);
          console.groupEnd();

          smd.parser_end(parser);
          thinking = false;

          if (nextPrompt) {
            const nextNextPrompt = nextPrompt;
            nextPrompt = null;
            return prompt(nextNextPrompt);
          }
        }

        function promptSync(text: string) {
          prompt(text).catch(console.error);
        }

        promptInput.addEventListener(
          'focus',
          () => {
            installDumbModel().then(console.log).catch(console.error);
          },
          { once: true },
        );

        promptInput.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter') {
            return;
          }

          promptSync(promptInput.value);
        });
      }

      main().then(console.log).catch(console.error);
    </script>
  </body>
</html>
